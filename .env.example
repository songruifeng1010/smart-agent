# 环境变量配置模板
# 复制此文件为.env并填写相应的值

# 服务器配置
PORT=3002
NODE_ENV=production
LOG_LEVEL=debug

# API配置
API_KEY=your_openai_api_key_here
MODEL=gpt-3.5-turbo
PROVIDER=openai

# 缓存配置
CACHE_EXPIRY=3600000
CACHE_SIZE_LIMIT=1000

# 智能助手配置
AGENT_NAME=SmartAgent
AGENT_VERSION=2.0.0

# 功能开关
LEARNING_ENABLED=true
SENTIMENT_ANALYSIS_ENABLED=true
TOPIC_TRACKING_ENABLED=true