.container {
  height: 100vh;
  background-color: #f5f5f5;
}

.chat-container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.chat-messages {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message {
  margin-bottom: 20rpx;
  max-width: 80%;
  padding: 15rpx 20rpx;
  border-radius: 24rpx;
}

.bot-message {
  background-color: #f1f0f0;
  margin-right: auto;
  border-bottom-left-radius: 8rpx;
}

.user-message-content {
  background-color: #e3f2fd;
  margin-left: auto;
  border-bottom-right-radius: 8rpx;
}

.message-content {
  word-wrap: break-word;
  font-size: 32rpx;
  line-height: 1.4;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: right;
}

.typing-indicator {
  display: flex;
  align-items: center;
  background-color: #f1f0f0;
  padding: 15rpx 20rpx;
  border-radius: 24rpx;
  border-bottom-left-radius: 8rpx;
  margin-bottom: 20rpx;
  max-width: 80%;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #999;
  border-radius: 50%;
  margin: 0 6rpx;
  animation: bounce 1.4s infinite ease-in-out both;
}

.typing-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.typing-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  } 40% {
    transform: scale(1);
  }
}

.quick-replies {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 15rpx 20rpx;
  border-top: 1rpx solid #e0e0e0;
  background-color: #fafafa;
}

.quick-reply {
  background-color: #e3f2fd;
  border: none;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #1976d2;
}

.quick-reply:hover {
  background-color: #bbdefb;
}

.chat-input {
  display: flex;
  padding: 15rpx 20rpx;
  border-top: 1rpx solid #e0e0e0;
  background-color: #fafafa;
  align-items: center;
}

#message-input {
  flex: 1;
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 24rpx;
  font-size: 32rpx;
  background-color: white;
}

#send-button {
  background-color: #667eea;
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-left: 16rpx;
  font-size: 32rpx;
  height: 64rpx;
  line-height: 64rpx;
}

#send-button:disabled {
  background-color: #ccc;
  cursor: not-allowed;
}
